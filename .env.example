# --- Database (Neon Postgres) ---
# Get from https://console.neon.tech/ → your project → Connection string
# Use the "Pooled connection" string from Neon (с -pooler в хосте).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/DBNAME?sslmode=require"

# --- NextAuth.js v5 ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# --- Telegram bot (заказы летят админу) ---
# Получи через @BotFather → /newbot
TELEGRAM_BOT_TOKEN=""
# Узнай свой chat_id через @userinfobot
TELEGRAM_ADMIN_CHAT_ID=""

# --- Public site config ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
