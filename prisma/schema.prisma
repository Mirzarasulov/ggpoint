// Prisma schema for ggpoint.
// Connection URL is configured in prisma.config.ts (loaded from .env.local).
// БД-схема следует Postgres-идиомам: snake_case + plural для таблиц.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Currencies ----------

// Каталог валют. Одна из них помечена как is_base (для нашего магазина — UZS,
// в ней хранятся все цены товаров и итоги заказов).
//
// Source ∈ MANUAL | CBU | OPEN_EXCHANGE — CHECK добавляется в миграции:
//   MANUAL          — введён вручную через админку
//   CBU             — Центробанк Узбекистана (cbu.uz API)
//   OPEN_EXCHANGE   — openexchangerates.org или аналоги

model Currency {
  id        String   @id @default(cuid())
  // ISO 4217 код: UZS, USD, EUR, RUB.
  code      String   @unique
  name      String // "Доллар США"
  symbol    String // "$", "€", "₽", "сум"
  // Количество знаков после запятой при отображении (UZS = 0, USD/EUR = 2).
  decimals  Int      @default(2)
  isBase    Boolean  @default(false) @map("is_base")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rates ExchangeRate[]

  @@index([isActive, sortOrder])
  @@map("currencies")
}

model ExchangeRate {
  id           String   @id @default(cuid())
  currencyCode String   @map("currency_code")
  currency     Currency @relation(fields: [currencyCode], references: [code], onDelete: Cascade)
  // Сколько единиц BASE-валюты (UZS) за 1 единицу currency.
  //   Пример: для USD — rateUzs = 12500.000000 (1 USD = 12 500 UZS)
  //   Для UZS (base) — rateUzs = 1
  rateUzs      Decimal  @map("rate_uzs") @db.Decimal(18, 6)
  validFrom    DateTime @default(now()) @map("valid_from")
  source       String   @default("MANUAL")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([currencyCode, validFrom(sort: Desc)])
  @@map("exchange_rates")
}

// ---------- Catalog ----------

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products           Product[]
  categoryAttributes CategoryAttribute[]

  @@index([sortOrder])
  @@map("categories")
}

// Справочник атрибутов товара. Один атрибут может относиться к нескольким
// категориям (например connection — и для мышей, и для клавиатур).
//
// type хранится как TEXT, CHECK добавляется в миграции:
//   type ∈ ENUM | STRING | NUMBER | BOOLEAN

model Attribute {
  id        String   @id @default(cuid())
  slug      String   @unique // "socket", "memory_type", "form_factor"
  name      String // "Сокет", "Тип памяти", "Форм-фактор"
  type      String   @default("ENUM")
  unit      String? // "ГБ", "Гц", "мм", "г"
  // Допустимые значения для type = ENUM. Игнорируется для других типов.
  options   String[] @default([])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  categoryAttributes CategoryAttribute[]

  @@map("attributes")
}

// M2M между категориями и атрибутами. Определяет какие атрибуты есть в категории
// и какие из них показывать как фильтры в каталоге.
model CategoryAttribute {
  categoryId  String    @map("category_id")
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attributeId String    @map("attribute_id")
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  isFilter    Boolean   @default(true) @map("is_filter")
  isRequired  Boolean   @default(false) @map("is_required")
  sortOrder   Int       @default(0) @map("sort_order")

  @@id([categoryId, attributeId])
  @@index([categoryId, sortOrder])
  @@map("category_attributes")
}

// Производитель / бренд товара. Сквозной фильтр по всем категориям.
model Brand {
  id        String   @id @default(cuid())
  slug      String   @unique // "samsung", "razer", "logitech"
  name      String // "Samsung", "Razer", "Logitech"
  logoUrl   String?  @map("logo_url")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]

  @@index([isActive, sortOrder])
  @@map("brands")
}

model Product {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String
  // Цена в сумах (целые числа, без копеек).
  priceUzs    Int     @map("price_uzs")
  oldPriceUzs Int?    @map("old_price_uzs")
  stock       Int     @default(0)
  isActive    Boolean @default(true) @map("is_active")
  isNew       Boolean @default(false) @map("is_new")

  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  brandId String? @map("brand_id")
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  // Спецификации товара. Структура: { "<attribute_slug>": <value> }
  // Например: { "socket": "AM5", "memory_type": "DDR5", "form_factor": "ATX" }
  // GIN-индекс для быстрых фильтров (`specs @> '{...}'`) — добавлен в миграции.
  specs Json @default("{}") @db.JsonB

  images     ProductImage[]
  orderItems OrderItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Покрывает каталог-запросы:
  //   WHERE category_id=? AND is_active=true ORDER BY created_at DESC
  @@index([categoryId, isActive, createdAt(sort: Desc)])
  @@index([brandId])
  // GIN-индекс для фильтрации по специфике (`specs @> '{...}'`).
  @@index([specs], type: Gin)
  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int      @default(0) @map("sort_order")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId, sortOrder])
  @@map("product_images")
}

// ---------- Auth (NextAuth.js v5 Prisma adapter) ----------

// UserRole: USER | ADMIN — хранится как TEXT, CHECK добавляется в миграции.

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  phone         String?
  role          String    @default("USER")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts Account[]
  sessions Session[]
  orders   Order[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------- Orders ----------

// Все статусы/типы хранятся как TEXT с CHECK constraint в миграции:
//   status          ∈ PENDING | CONFIRMED | SHIPPED | DELIVERED | CANCELLED
//   delivery_method ∈ PICKUP | COURIER
//   payment_method  ∈ CASH | CARD_TRANSFER

model Order {
  id     String @id @default(cuid())
  // Автоинкрементный номер. Человеко-читаемое представление ("GG-000123")
  // формируется на уровне приложения.
  number Int    @unique @default(autoincrement())
  status String @default("PENDING")

  // Покупатель — либо привязан к users, либо гостевой checkout.
  userId     String? @map("user_id")
  user       User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestEmail String? @map("guest_email")
  guestName  String? @map("guest_name")
  phone      String

  // Доставка
  deliveryMethod String  @default("COURIER") @map("delivery_method")
  address        String?
  city           String  @default("Ташкент")
  comment        String?

  // Оплата
  paymentMethod String @default("CASH") @map("payment_method")

  // Итоги (snapshot)
  subtotalUzs Int @map("subtotal_uzs")
  deliveryUzs Int @default(0) @map("delivery_uzs")
  totalUzs    Int @map("total_uzs")

  // Связь с уведомлением в Telegram
  telegramMessageId Int? @map("telegram_message_id")

  items OrderItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, createdAt(sort: Desc)])
  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Snapshot товара на момент заказа.
  productId    String?  @map("product_id")
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  nameSnap     String   @map("name_snap")
  priceUzsSnap Int      @map("price_uzs_snap")
  quantity     Int

  @@index([orderId])
  @@map("order_items")
}
