# Включаем движок перезаписи
RewriteEngine On

# ====== РЕДИРЕКТ С product.html НА product.php ======
# Все запросы вида product.html?id=123 будут перенаправлены на product.php?id=123
RewriteRule ^product\.html$ product.php [L,R=301]

# ====== КРАСИВЫЕ URL (опционально) ======
# Если хотите, чтобы работало: /product/123
# RewriteRule ^product/([0-9]+)$ product.php?id=$1 [L]

# ====== ЗАЩИТА ОТ ДОСТУПА К ПАПКАМ ======
Options -Indexes

# ====== КЭШИРОВАНИЕ СТАТИКИ ======
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
</IfModule>

# ====== СЖАТИЕ ======
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json
</IfModule>
